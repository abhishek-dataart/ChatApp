{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist/out-tsc/spec",
    "types": ["jest", "node"],
    "esModuleInterop": true,
    "target": "ES2022",
    "module": "ES2022",
    "emitDecoratorMetadata": true
  },
  "include": [
    "src/**/*.spec.ts",
    "src/**/*.d.ts",
    "src/testing/**/*.ts",
    "setup-jest.ts"
  ]
}
