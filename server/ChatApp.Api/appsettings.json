{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "Microsoft.AspNetCore.SignalR": "Warning",
      "Microsoft.AspNetCore.Http.Connections": "Warning",
      "ChatApp": "Information"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "Host=db;Port=5432;Database=chatapp;Username=chatapp;Password=chatapp"
  },
  "ChatApp": {
    "Files": {
      "Root": "/var/chatapp/files"
    },
    "Cookie": {
      "Name": "chatapp_session",
      "SameSite": "Lax",
      "Secure": true
    },
    "RateLimits": {
      "MessagesPerMinute": 60
    },
    "Attachments": {
      "MaxImageBytes": 3145728,
      "MaxFileBytes": 20971520,
      "MaxPerMessage": 10,
      "UnlinkedTtlMinutes": 60,
      "PurgeIntervalMinutes": 10,
      "Scanner": "clamav",
      "ClamAv": {
        "Host": "clamav",
        "Port": 3310,
        "Timeout": "00:00:30",
        "MaxStreamBytes": 26214400
      }
    }
  }
}
